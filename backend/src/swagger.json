{
  "openapi": "3.0.0",
  "info": {
    "title": "Stadt-Service API",
    "version": "1.0.0",
    "description": "Documentation for the Stadt-Service Application"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/companies": {
      "get": {
        "summary": "Fetch companies list with filtering and pagination",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "aglomerationId",
            "in": "query",
            "required": false,
            "description": "Filter by agglomeration ID",
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "required": false,
            "description": "Filter by category ID",
            "schema": {
              "type": "integer",
              "example": 4
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (default is 1)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "example": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of records per page",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 30,
              "example": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompaniesListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/companies/{id}": {
      "get": {
        "summary": "Fetch detailed information about a company by ID",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the company to retrieve",
            "schema": {
              "type": "string",
              "example": "12"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detailed information about the company fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyDetailsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Company with the specified ID not found"
          }
        }
      }
    },
    "/cities": {
      "get": {
        "summary": "Getting list of aglomerations",
        "tags": ["Aglomerations"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AglomerationsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "Getting list of categories",
        "tags": ["Categories"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoriesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reviews": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Get a list of reviews",
        "responses": {
          "200": {
            "description": "Successful response"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Autowerkstatt"
          },
          "description": {
            "type": "string",
            "example": "Kfz-Reparatur, Inspektion, Reifenservice, Fahrzeugdiagnose"
          }
        },
        "required": ["id", "name", "description"]
      },
      "CategoriesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "object",
            "properties": {
              "categories": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Category"
                }
              },
              "total": {
                "type": "integer",
                "example": 5
              }
            },
            "required": ["categories", "total"]
          }
        },
        "required": ["status", "code", "data"]
      },
      "Aglomeration": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Frankfurt am Main"
          }
        },
        "required": ["id", "name"]
      },
      "AglomerationsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Aglomeration"
            }
          }
        },
        "required": ["status", "code", "data"]
      },
      "Address": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "12"
          },
          "street": {
            "type": "string",
            "example": "Bronnbachergasse"
          },
          "houseNr": {
            "type": "string",
            "example": "3"
          },
          "additionalAdrsInfo": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "zip": {
            "type": "string",
            "example": "97070"
          },
          "city": {
            "type": "string",
            "example": "Würzburg"
          },
          "state": {
            "type": "string",
            "example": "Bayern"
          },
          "latitude": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "example": null
          },
          "longitude": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "example": null
          },
          "aglomerationId": {
            "type": "integer",
            "example": 3
          },
          "aglomerationName": {
            "type": "string",
            "example": "Würzburg"
          }
        },
        "required": [
          "id",
          "street",
          "houseNr",
          "additionalAdrsInfo",
          "zip",
          "city",
          "state",
          "latitude",
          "longitude",
          "aglomerationId",
          "aglomerationName"
        ]
      },
      "Email": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "72"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "maria.wagner64@icloud.com"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": null
          }
        },
        "required": ["id", "email", "description"]
      },
      "Website": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "12"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "example": "http://www.ludwigkoerner.de/"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": null
          }
        },
        "required": ["id", "url", "description"]
      },
      "PhoneNumber": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "12"
          },
          "number": {
            "type": "string",
            "example": " + 49 93152340"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "type": {
            "type": "string",
            "example": "work"
          }
        },
        "required": ["id", "number", "description", "type"]
      },
      "CompanyDetails": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "12"
          },
          "name": {
            "type": "string",
            "example": "Bicycles and Repair Ludwig Körner"
          },
          "description": {
            "type": "string",
            "example": "Fahrräder und Reparaturen Ludwig Körner"
          },
          "logo": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Email"
            }
          },
          "websites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Website"
            }
          },
          "phoneNumbers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PhoneNumber"
            }
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "logo",
          "categories",
          "addresses",
          "emails",
          "websites",
          "phoneNumbers"
        ]
      },
      "CompanyDetailsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/CompanyDetails"
          }
        },
        "required": ["status", "code", "data"]
      },
      "Coordinates": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "example": null
          },
          "longitude": {
            "type": "number",
            "format": "float",
            "nullable": true,
            "example": null
          }
        },
        "required": ["latitude", "longitude"]
      },
      "CompanyAddressListItem": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string",
            "example": "Im Trierischen Hof"
          },
          "houseNr": {
            "type": "string",
            "example": "17"
          },
          "additionalAdrsInfo": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "aglomerationId": {
            "type": "integer",
            "example": 1
          },
          "zip": {
            "type": "string",
            "example": "60311"
          },
          "city": {
            "type": "string",
            "example": "Frankfurt"
          },
          "state": {
            "type": "string",
            "example": "Hessen"
          },
          "coordinates": {
            "$ref": "#/components/schemas/Coordinates"
          }
        },
        "required": [
          "street",
          "houseNr",
          "additionalAdrsInfo",
          "aglomerationId",
          "zip",
          "city",
          "state",
          "coordinates"
        ]
      },
      "CompanyListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "131"
          },
          "name": {
            "type": "string",
            "example": "Änderungsschneiderei Zauberei"
          },
          "description": {
            "type": "string",
            "example": "Clothing alterations and tailoring services"
          },
          "logo": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Category"
            }
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompanyAddressListItem"
            }
          }
        },
        "required": ["id", "name", "description", "logo", "categories", "addresses"]
      },
      "CompaniesListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "code": {
            "type": "integer",
            "example": 200
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CompanyListItem"
            }
          }
        },
        "required": ["status", "code", "data"]
      }
    }
  }
}
